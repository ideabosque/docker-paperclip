# Clone the repository first:
# git clone https://github.com/paperclipai/paperclip.git
# cd paperclip

# Copy this file to .env and update the values:
# cp .env.example .env

# Required: Authentication secret (generate a secure random string)
BETTER_AUTH_SECRET=change-this-to-a-secure-random-secret

# Ollama API key (used by Paperclip to authenticate against Ollama)
OLLAMA_API_KEY=

# Public URL for the Paperclip instance
PAPERCLIP_PUBLIC_URL=http://localhost:3100

# PostgreSQL settings
POSTGRES_VERSION=17
POSTGRES_USER=paperclip
POSTGRES_PASSWORD=paperclip
POSTGRES_DB=paperclip

# Optional: Host paths for persistent data volumes
# If not set, Docker named volumes will be used
# Uncomment and set paths to mount volumes to host filesystem:
# PGDATA_HOST_PATH=./data/postgres
# PAPERCLIP_DATA_HOST_PATH=./data/paperclip

# Optional: Exposed ports (default values shown)
# Uncomment to use custom ports:
# POSTGRES_PORT=5432
# PAPERCLIP_PORT=3100
